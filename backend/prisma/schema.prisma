// schema.prisma

// Enums
//   UserRole        — WORKFORCE_PLANNER | HR | CEO | CANDIDATE
//   PlanningPeriod  — ANNUAL | QUARTERLY
//   PlanStatus      — lifecycle states a plan moves through during approval
//   EmploymentType  — FULL_TIME | PART_TIME | CONTRACT
//   Priority        — HIGH | MEDIUM | LOW
//
// Models
//   User            — application users; role drives access control throughout
//                     the API. Stores a bcrypt password_hash and an optional
//                     email verification_token.
//   Department      — organisational units with static baseline headcount fields
//                     (approved_hc, budgeted_hc, current_hc).
//   PlanningCycle   — fiscal-year windows that gate plan submissions; only one
//                     cycle can be active (is_active = true) at a time.
//   WorkforcePlan   — the core entity. Belongs to a Department and a User,
//                     optionally linked to a PlanningCycle. Tracks version
//                     number and plan lifecycle status.
//   PlanPosition    — individual roles requested within a plan (title, count,
//                     employment type, priority). Cascades-delete with the plan.
//   PlanVersion     — immutable JSON snapshot of a plan at a point in time,
//                     used for audit / history. Cascades-delete with the plan.
//   PlanAttachment  — file metadata for documents uploaded alongside a plan.
//                     Cascades-delete with the plan.
//   ApprovalLog     — append-only audit trail of every status transition and
//                     reviewer action on a plan. Cascades-delete with the plan.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  WORKFORCE_PLANNER
  HR
  CEO
  CANDIDATE
}

enum PlanningPeriod {
  ANNUAL
  QUARTERLY
}

enum PlanStatus {
  DRAFT
  SUBMITTED
  HR_REVIEW
  FINANCE_REVIEW
  CEO_REVIEW
  APPROVED
  REJECTED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  password_hash      String
  full_name          String
  role               UserRole        @default(WORKFORCE_PLANNER)
  title              String?
  is_verified        Boolean         @default(false)
  verification_token String?
  is_active          Boolean         @default(true)
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  plans              WorkforcePlan[]
  plan_versions      PlanVersion[]
  approval_logs      ApprovalLog[]

  @@map("users")
}

model Department {
  id          String          @id @default(uuid())
  name        String          @unique
  code        String?         @unique
  approved_hc Int             @default(0)
  budgeted_hc Int             @default(0)
  current_hc  Int             @default(0)
  created_at  DateTime        @default(now())
  plans       WorkforcePlan[]

  @@map("departments")
}

model PlanningCycle {
  id          String          @id @default(uuid())
  fiscal_year Int
  name        String
  start_date  DateTime
  end_date    DateTime
  is_active   Boolean         @default(true)
  created_at  DateTime        @default(now())
  plans       WorkforcePlan[]

  @@map("planning_cycles")
}

model WorkforcePlan {
  id              String           @id @default(uuid())
  title           String
  department_id   String
  fiscal_year     Int
  planning_period PlanningPeriod   @default(ANNUAL)
  quarter         Int?
  start_date      DateTime?
  end_date        DateTime?
  justification   String?
  status          PlanStatus       @default(DRAFT)
  version         Int              @default(1)
  cycle_id        String?
  created_by_id   String
  last_saved_at   DateTime         @default(now())
  submitted_at    DateTime?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  department      Department       @relation(fields: [department_id], references: [id])
  cycle           PlanningCycle?   @relation(fields: [cycle_id], references: [id])
  created_by      User             @relation(fields: [created_by_id], references: [id])
  positions       PlanPosition[]
  attachments     PlanAttachment[]
  versions        PlanVersion[]
  approval_logs   ApprovalLog[]

  @@map("workforce_plans")
}

model PlanPosition {
  id              String         @id @default(uuid())
  plan_id         String
  title           String
  count           Int            @default(1)
  employment_type EmploymentType @default(FULL_TIME)
  priority        Priority       @default(MEDIUM)
  plan            WorkforcePlan  @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("plan_positions")
}

model PlanVersion {
  id            String        @id @default(uuid())
  plan_id       String
  version       Int
  snapshot      Json
  created_by_id String
  created_at    DateTime      @default(now())
  plan          WorkforcePlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  created_by    User          @relation(fields: [created_by_id], references: [id])

  @@map("plan_versions")
}

model PlanAttachment {
  id         String        @id @default(uuid())
  plan_id    String
  filename   String
  filepath   String
  mimetype   String?
  size       Int?
  created_at DateTime      @default(now())
  plan       WorkforcePlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("plan_attachments")
}

model ApprovalLog {
  id          String        @id @default(uuid())
  plan_id     String
  actor_id    String
  action      String
  comment     String?
  from_status PlanStatus?
  to_status   PlanStatus
  created_at  DateTime      @default(now())
  plan        WorkforcePlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  actor       User          @relation(fields: [actor_id], references: [id])

  @@map("approval_logs")
}
