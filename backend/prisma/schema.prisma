generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  WORKFORCE_PLANNER
  HR
  CEO
  CANDIDATE
  HR_ADMIN
}

enum PlanningPeriod {
  ANNUAL
  QUARTERLY
}

enum PlanStatus {
  DRAFT
  SUBMITTED
  HR_APPROVED
  APPROVED
  REJECTED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  password_hash      String
  full_name          String
  role               UserRole        @default(WORKFORCE_PLANNER)
  title              String?
  permissions        String[]        @default([])
  is_verified        Boolean         @default(false)
  verification_token String?
  is_active          Boolean         @default(true)
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  plans              WorkforcePlan[]
  plan_versions      PlanVersion[]
  approval_logs      ApprovalLog[]

  @@map("users")
}

model RolePermission {
  role        UserRole @id
  permissions String[] @default([])
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("role_permissions")
}

model Department {
  id          String          @id @default(uuid())
  name        String          @unique
  code        String?         @unique
  approved_hc Int             @default(0)
  current_hc  Int             @default(0)
  created_at  DateTime        @default(now())
  plans       WorkforcePlan[]

  @@map("departments")
}

model WorkforcePlan {
  id              String           @id @default(uuid())
  title           String
  department_id   String
  fiscal_year     Int
  planning_period PlanningPeriod   @default(ANNUAL)
  quarter         Int?
  justification   String?
  status          PlanStatus       @default(DRAFT)
  version         Int              @default(1)
  created_by_id   String
  last_saved_at   DateTime         @default(now())
  submitted_at    DateTime?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  department      Department       @relation(fields: [department_id], references: [id])
  created_by      User             @relation(fields: [created_by_id], references: [id])
  positions       PlanPosition[]
  attachments     PlanAttachment[]
  versions        PlanVersion[]
  approval_logs   ApprovalLog[]

  @@map("workforce_plans")
}

model PlanPosition {
  id              String         @id @default(uuid())
  plan_id         String
  title           String
  count           Int            @default(1)
  employment_type EmploymentType @default(FULL_TIME)
  priority        Priority       @default(MEDIUM)
  plan            WorkforcePlan  @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("plan_positions")
}

model PlanVersion {
  id            String        @id @default(uuid())
  plan_id       String
  version       Int
  snapshot      Json
  created_by_id String
  created_at    DateTime      @default(now())
  plan          WorkforcePlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  created_by    User          @relation(fields: [created_by_id], references: [id])

  @@map("plan_versions")
}

model PlanAttachment {
  id         String        @id @default(uuid())
  plan_id    String
  filename   String
  filepath   String
  mimetype   String?
  size       Int?
  created_at DateTime      @default(now())
  plan       WorkforcePlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("plan_attachments")
}

model ApprovalLog {
  id          String        @id @default(uuid())
  plan_id     String
  actor_id    String
  action      String
  comment     String?
  from_status PlanStatus?
  to_status   PlanStatus
  created_at  DateTime      @default(now())
  plan        WorkforcePlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  actor       User          @relation(fields: [actor_id], references: [id])

  @@map("approval_logs")
}
