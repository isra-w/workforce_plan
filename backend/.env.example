# ── Database ────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/workforce_db?schema=public"

# ── Authentication ───────────────────────────────────────────────────────────
# Required. Secret key used to sign and verify JWTs.
# Use a long, random string in production (e.g. openssl rand -hex 64).
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Optional. JWT token expiry. Default: 7d
JWT_EXPIRES_IN="7d"

# ── Server ───────────────────────────────────────────────────────────────────
# Optional. Port the API listens on. Default: 5000
PORT=5000

# Optional. Runtime environment: development | production | test. Default: development
NODE_ENV="development"

# ── CORS ─────────────────────────────────────────────────────────────────────
# Optional. Allowed frontend origin. Default: http://localhost:5173
FRONTEND_URL="http://localhost:5173"

# ── File uploads ─────────────────────────────────────────────────────────────
# Optional. Absolute path where uploaded attachments are stored.
# Default: <project-root>/uploads
# UPLOAD_DIR="/var/www/workforce/uploads"

# Optional. Maximum upload size in bytes. Default: 10485760 (10 MB)
# UPLOAD_MAX_BYTES=10485760
